# ============================================
# No-Slop Research — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit your .env file — it contains secrets.

# ---- LLM Provider (required) ----
# Any OpenAI-compatible API works (OpenAI, OpenRouter, Anthropic via proxy, etc.)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# ---- TinyFish MCP (required for web research) ----
# Get your key from: https://tinyfish.io
TINYFISH_API_KEY=your_tinyfish_key_here

# ---- Optional: Additional Research APIs ----
# SerpAPI for Google search (optional, TinyFish handles most cases)
SERPAPI_KEY=

# ---- Dashboard ----
DASHBOARD_PORT=5060
DASHBOARD_HOST=0.0.0.0

# ---- Research Pipeline Settings ----
# Max adversarial rounds (default: 3)
MAX_ADVERSARIAL_ROUNDS=3
# Max research subagents per phase (default: 4)
MAX_RESEARCH_AGENTS=4
# Timeout per subagent in seconds (default: 300)
SUBAGENT_TIMEOUT=300
